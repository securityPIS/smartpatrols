<?xml version="1.0" encoding="utf-8"?>
<!--
Tujuan: Adaptive round launcher icon SmartPatrol.
Caller: Android launcher API 26+.
Dependensi: ic_launcher_background dan ic_launcher_foreground.
Main Functions: Menggabungkan background dark navy dan foreground logo SmartPatrol.
Side Effects: Mengubah round icon aplikasi pada perangkat Android modern.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@color/ic_launcher_background"/>
    <foreground android:drawable="@drawable/ic_launcher_foreground"/>
</adaptive-icon>
