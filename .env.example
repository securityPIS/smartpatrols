VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=replace-with-local-or-cloud-anon-key
VITE_ENABLE_CLOUD_SYNC=1
VITE_ENABLE_CLOUD_SYNC_WRITE=1
VITE_TRUSTED_TIME_URL=http://127.0.0.1:54321/functions/v1/server-time

# Web push (FCM) — konfigurasi Firebase Web (publik, aman di klien).
# Ambil dari Firebase Console: Project Settings > General (config) & Cloud Messaging (VAPID key).
VITE_FIREBASE_API_KEY=replace-with-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=replace-with-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=replace-with-project-id
VITE_FIREBASE_STORAGE_BUCKET=replace-with-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=replace-with-sender-id
VITE_FIREBASE_APP_ID=replace-with-app-id
VITE_FCM_VAPID_KEY=replace-with-web-push-vapid-key

# Server-side only. Jangan expose ke client/browser.
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
SMARTPATROL_SETUP_TOKEN=replace-with-local-setup-token
# Edge function send-push (di-set sebagai Supabase secret, bukan di file ini di production):
#   FCM_SERVICE_ACCOUNT = isi penuh file JSON service account Firebase (Project Settings > Service accounts)
#   APP_URL             = URL aplikasi produksi untuk deep-link klik notifikasi (mis. https://smartpatrol.example.com)
